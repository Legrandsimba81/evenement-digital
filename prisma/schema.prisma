generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"  // au lieu de "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  role          String    @default("USER") // Valeurs possibles: USER, ADMIN
  events        Event[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Event {
  id             String    @id @default(cuid())
  title          String
  type           String
  description    String?
  invitationText String?
  program        String?   // programme de la fête (texte formaté)
  location       String
  date           DateTime
  time           String
  imageUrl       String?
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests         Guest[]
  messages       Message[]
  slug           String    @unique
  whatsappNumber String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Guest {
  id            String    @id @default(cuid())
  title         String?   // Mr, Mme, Dr, Papa, Maman, Excellence
  firstName     String
  lastName      String
  eventId       String
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([firstName, lastName, eventId])
}

model Message {
  id            String    @id @default(cuid())
  content       String
  guestName     String
  eventId       String
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}